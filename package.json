{
  "name": "film-wall",
  "type": "module",
  "version": "0.1.0",
  "description": "个人电影墙 — 基于 Astro 构建的静态观影记录网站",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run data:normalize && npm run data:validate && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "data:normalize": "tsx scripts/normalize-movies.ts",
    "data:validate": "tsx scripts/validate-data.ts",
    "check": "astro check && npm run data:validate",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.7",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
