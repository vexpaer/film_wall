---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BookCard from "../../components/BookCard.astro";
import { siteConfig } from "../../config/site";
import { getAllBooks } from "../../utils/books";

const books = await getAllBooks();
---

<BaseLayout
  title="书架"
  description={`共 ${books.length} 本书 — ${siteConfig.description}`}
>
  <div class="books-header">
    <div class="container">
      <div class="books-header__inner animate-fade-in-up">
        <span class="books-header__eyebrow">阅读档案</span>
        <h1 class="books-header__title">书架</h1>
        <p class="books-header__desc">共 <strong>{books.length}</strong> 本读过的书</p>
      </div>
    </div>
  </div>

  <div class="container books-content animate-fade-in-up delay-100">
    {books.length > 0 ? (
      <div class="movie-grid" aria-label="书籍列表">
        {books.map((book) => <BookCard book={book} />)}
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-state__icon" aria-hidden="true">📚</div>
        <p class="empty-state__title">书架还是空的</p>
        <p class="empty-state__desc">运行豆瓣同步 Action 后，读过的书会出现在这里。</p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .books-header {
    padding: var(--space-20) 0 var(--space-10);
    border-bottom: 1px solid var(--border-subtle);
  }

  .books-header__inner {
    max-width: 600px;
  }

  .books-header__eyebrow {
    display: block;
    margin-bottom: var(--space-3);
    color: var(--color-accent);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .books-header__title {
    margin-bottom: var(--space-3);
    font-size: var(--text-5xl);
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .books-header__desc {
    color: var(--text-muted);
    font-size: var(--text-lg);
  }

  .books-header__desc strong {
    color: var(--color-accent);
  }

  .books-content {
    padding-top: var(--space-8);
    padding-bottom: var(--space-20);
  }
</style>
