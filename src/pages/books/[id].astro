---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StarRating from "../../components/StarRating.astro";
import { siteConfig } from "../../config/site";
import { formatDate, formatRating } from "../../utils/data";
import { getAllBooks } from "../../utils/books";

export async function getStaticPaths() {
  const books = await getAllBooks();
  return books.map((book) => ({ params: { id: book.id }, props: { book } }));
}

const { book } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  title={`${book.title}${book.year ? ` (${book.year})` : ""}`}
  description={book.shortComment || book.summary?.slice(0, 150) || `${book.title} — ${siteConfig.title}`}
  ogImage={book.cover}
>
  <div class="book-detail">
    <div class="container">
      <a href={`${base}/books/`} class="book-detail__back">← 书架</a>

      <div class="book-detail__hero">
        <div class="book-cover">
          {book.cover ? (
            <img
              src={book.cover}
              data-fallback-src={book.coverFallback}
              alt={`${book.title} 封面`}
              referrerpolicy="no-referrer"
              onerror="const fallback=this.dataset.fallbackSrc;if(fallback){this.removeAttribute('data-fallback-src');this.src=fallback;}else{this.style.display='none';this.nextElementSibling.style.display='flex';}"
            />
            <div class="book-cover__placeholder" style="display:none;">📖</div>
          ) : (
            <div class="book-cover__placeholder">📖</div>
          )}
        </div>

        <div class="book-info">
          <span class="tag tag--accent">书籍</span>
          <h1>{book.title}</h1>
          {book.subtitle && <p class="book-info__subtitle">{book.subtitle}</p>}
          {book.authors.length > 0 && <p class="book-info__authors">{book.authors.join(" / ")}</p>}

          <dl class="book-meta">
            {book.publisher && <div><dt>出版社</dt><dd>{book.publisher}</dd></div>}
            {book.publishDate && <div><dt>出版</dt><dd>{book.publishDate}</dd></div>}
            {book.pages && <div><dt>页数</dt><dd>{book.pages} 页</dd></div>}
          </dl>

          <div class="book-ratings">
            {book.doubanRating && (
              <div><span>豆瓣评分</span><strong>{formatRating(book.doubanRating)}</strong><small>/ 10</small></div>
            )}
            {book.personalRating && (
              <div><span>我的评分</span><StarRating rating={book.personalRating} size="md" /></div>
            )}
          </div>

          {book.finishedAt && <p class="book-info__date">读完于 {formatDate(book.finishedAt)}</p>}
          {book.doubanUrl && (
            <a href={book.doubanUrl} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              豆瓣页面
            </a>
          )}
        </div>
      </div>

      <div class="book-detail__body">
        {book.shortComment && (
          <section>
            <h2>短评</h2>
            <blockquote>{book.shortComment}</blockquote>
          </section>
        )}
        {book.summary && (
          <section>
            <h2>内容简介</h2>
            <p>{book.summary}</p>
          </section>
        )}
        {book.tags.length > 0 && (
          <section>
            <h2>标签</h2>
            <div class="book-tags">{book.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
          </section>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .book-detail {
    padding: var(--space-8) 0 var(--space-20);
  }

  .book-detail__back {
    display: inline-flex;
    margin-bottom: var(--space-8);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .book-detail__back:hover {
    color: var(--color-accent);
  }

  .book-detail__hero {
    display: grid;
    grid-template-columns: minmax(180px, 260px) 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  .book-cover {
    overflow: hidden;
    aspect-ratio: 2 / 3;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    background: var(--bg-card);
    box-shadow: var(--shadow-xl);
  }

  .book-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .book-cover__placeholder {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
  }

  .book-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .book-info h1 {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .book-info__subtitle,
  .book-info__authors,
  .book-info__date {
    color: var(--text-muted);
  }

  .book-info__authors {
    color: var(--text-secondary);
    font-size: var(--text-lg);
  }

  .book-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .book-meta div {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .book-meta dt,
  .book-ratings span {
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .book-meta dd {
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }

  .book-ratings {
    display: flex;
    gap: var(--space-8);
    padding: var(--space-4);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
  }

  .book-ratings div {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .book-ratings strong {
    color: var(--color-accent);
    font-size: var(--text-3xl);
  }

  .book-ratings small {
    color: var(--text-muted);
  }

  .book-detail__body {
    display: grid;
    gap: var(--space-10);
    max-width: 800px;
    margin-top: var(--space-16);
  }

  .book-detail__body h2 {
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-subtle);
    font-size: var(--text-lg);
  }

  .book-detail__body p,
  .book-detail__body blockquote {
    color: var(--text-secondary);
    line-height: 1.8;
    white-space: pre-line;
  }

  .book-detail__body blockquote {
    padding: var(--space-4) var(--space-5);
    border-left: 3px solid var(--color-accent);
    background: var(--bg-card);
  }

  .book-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  @media (max-width: 640px) {
    .book-detail__hero {
      grid-template-columns: 120px 1fr;
      gap: var(--space-5);
    }

    .book-info h1 {
      font-size: var(--text-3xl);
    }

    .book-meta,
    .book-ratings {
      grid-column: 1 / -1;
    }
  }
</style>
