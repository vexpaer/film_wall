---
/**
 * 关于页面
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import { getAllMovies, getStats } from "../utils/data";

const movies = await getAllMovies();
const stats = await getStats();

// 最后更新时间（用构建时间）
const buildTime = new Date().toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title="关于"
  description={`关于 ${siteConfig.title} — ${siteConfig.description}`}
>
  <div class="page-header">
    <div class="container">
      <div class="animate-fade-in-up">
        <span class="page-header__eyebrow">关于本站</span>
        <h1 class="page-header__title">About</h1>
      </div>
    </div>
  </div>

  <div class="container container-md">
    <div class="about-content animate-fade-in-up delay-100">

      <!-- 简介 -->
      <section class="about-section" aria-labelledby="intro-heading">
        <h2 class="about-section__title" id="intro-heading">这是什么？</h2>
        <p>
          这是 <strong>{siteConfig.author}</strong> 的个人观影记录档案。
          记录看过的电影、个人评分和感受，不代表任何专业影评立场。
        </p>
        <p>
          目前共记录了 <strong>{stats.total}</strong> 部影视作品，
          其中 <strong>{stats.ratedCount}</strong> 部记录了个人评分。
        </p>
      </section>

      <!-- 数据来源 -->
      <section class="about-section" aria-labelledby="source-heading">
        <h2 class="about-section__title" id="source-heading">数据来源</h2>
        <p>
          电影数据主要来自
          <a href="https://movie.douban.com" target="_blank" rel="noopener noreferrer" class="about-link">
            豆瓣电影
          </a>
          的观影记录，通过
          <a href="https://github.com/lizheming/doumark-action" target="_blank" rel="noopener noreferrer" class="about-link">
            doumark-action
          </a>
          自动同步。
        </p>
        <p>
          部分电影的长评、标签和额外信息由我手动补充，存储在仓库的
          <code>data/manual/movies.json</code> 中。
          手动数据的优先级高于豆瓣导入数据。
        </p>
      </section>

      <!-- 技术栈 -->
      <section class="about-section" aria-labelledby="tech-heading">
        <h2 class="about-section__title" id="tech-heading">如何生成</h2>
        <p>
          网站使用
          <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="about-link">Astro</a>
          构建，完全静态，部署在 GitHub Pages 上。
        </p>
        <ul class="about-list">
          <li>豆瓣观影数据通过 GitHub Actions 定时同步</li>
          <li>数据经过标准化处理，生成统一的 JSON 格式</li>
          <li>Astro 在构建时读取数据，生成静态 HTML 页面</li>
          <li>构建产物自动部署到 GitHub Pages</li>
          <li>整个流程无需服务器，100% 静态</li>
        </ul>
        <div class="tech-stack">
          <span class="tag">Astro</span>
          <span class="tag">TypeScript</span>
          <span class="tag">GitHub Actions</span>
          <span class="tag">GitHub Pages</span>
          <span class="tag">豆瓣 API</span>
        </div>
      </section>

      <!-- 更新信息 -->
      <section class="about-section" aria-labelledby="update-heading">
        <h2 class="about-section__title" id="update-heading">更新信息</h2>
        <p>
          本站最后构建于 <strong>{buildTime}</strong>。
          豆瓣数据每周自动同步一次，也可以通过 GitHub Actions 手动触发。
        </p>
      </section>

      <!-- GitHub 链接 -->
      {siteConfig.githubUrl && (
        <section class="about-section" aria-labelledby="github-heading">
          <h2 class="about-section__title" id="github-heading">开源</h2>
          <p>本项目代码公开在 GitHub 上。</p>
          <a
            href={siteConfig.githubUrl}
            class="btn btn-secondary about-github-btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span aria-hidden="true">⚙</span>
            查看源代码
          </a>
        </section>
      )}

    </div>

    <div style="height: var(--space-20);"></div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-20) 0 var(--space-10);
    border-bottom: 1px solid var(--border-subtle);
  }

  .page-header__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .page-header__title {
    font-size: var(--text-5xl);
    font-weight: 900;
    letter-spacing: -0.04em;
  }

  .about-content {
    padding-top: var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .about-section__title {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text-primary);
  }

  .about-section p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-3);
  }

  .about-section p:last-child {
    margin-bottom: 0;
  }

  .about-section strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .about-section code {
    background: var(--bg-elevated);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.875em;
    color: var(--color-accent);
  }

  .about-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity var(--transition-fast);
  }

  .about-link:hover {
    opacity: 0.8;
  }

  .about-list {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .about-list li {
    color: var(--text-secondary);
    padding-left: var(--space-5);
    position: relative;
    line-height: 1.6;
  }

  .about-list li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .about-github-btn {
    margin-top: var(--space-2);
    width: fit-content;
  }
</style>
