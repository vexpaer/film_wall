---
/**
 * 404 页面
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="404 — 页面未找到" description="页面不存在">
  <div class="not-found">
    <div class="container">
      <div class="not-found__content animate-fade-in-up">
        <div class="not-found__film" aria-hidden="true">🎞</div>
        <h1 class="not-found__code">404</h1>
        <h2 class="not-found__title">镜头之外</h2>
        <p class="not-found__desc">
          这个页面不在档案里。<br />
          也许它从未存在，或者已经被剪辑掉了。
        </p>
        <div class="not-found__actions">
          <a href={`${base}/`} class="btn btn-primary">回到首页</a>
          <a href={`${base}/movies/`} class="btn btn-secondary">浏览电影墙</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100dvh - var(--nav-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-20) 0;
  }

  .not-found__content {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .not-found__film {
    font-size: 4rem;
    margin-bottom: var(--space-4);
    opacity: 0.6;
  }

  .not-found__code {
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 1;
    background: linear-gradient(135deg, var(--text-muted) 0%, var(--border-medium) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--space-2);
  }

  .not-found__title {
    font-size: var(--text-3xl);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
    color: var(--text-primary);
  }

  .not-found__desc {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  .not-found__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
</style>
