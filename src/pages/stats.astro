---
/**
 * 统计页面
 * 个人观影数据可视化
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import { getAllMovies, getStats, formatRating } from "../utils/data";

const movies = await getAllMovies();
const stats = await getStats();


---

<BaseLayout
  title="观影统计"
  description={`${siteConfig.author} 的个人观影统计 — ${stats.total} 部电影`}
>
  <!-- 页面标题 -->
  <div class="page-header">
    <div class="container">
      <div class="animate-fade-in-up">
        <span class="page-header__eyebrow">数据分析</span>
        <h1 class="page-header__title">观影统计</h1>
        <p class="page-header__desc">
          {stats.total} 部电影的个人观影数据
        </p>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- ── 快速概览 ─────────────────────────────────────── -->
    <section class="section animate-fade-in-up delay-100" aria-labelledby="overview-heading">
      <h2 class="sr-only" id="overview-heading">观影概览</h2>
      <div class="overview-grid">
        <div class="stat-card">
          <div class="stat-card__number">{stats.total}</div>
          <div class="stat-card__label">总电影数</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__number">
            {stats.avgRating > 0 ? formatRating(stats.avgRating) : '—'}
          </div>
          <div class="stat-card__label">平均评分</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__number">{stats.favorites}</div>
          <div class="stat-card__label">收藏电影</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__number">
            {stats.total > 0 ? Math.round(stats.favorites / stats.total * 100) : 0}%
          </div>
          <div class="stat-card__label">收藏占比</div>
        </div>
      </div>
    </section>

    {movies.length === 0 ? (
      <div class="empty-state">
        <div class="empty-state__icon" aria-hidden="true">📊</div>
        <p class="empty-state__title">暂无数据</p>
        <p class="empty-state__desc">添加电影后统计图表将显示在这里</p>
      </div>
    ) : (
      <>
        <!-- 两列布局 -->
        <div class="stats-two-col">
          <!-- ── 按年观看量 ────────────────────────────── -->
          {stats.byWatchYear.length > 0 && (
            <section class="stats-card animate-fade-in-up delay-200" aria-labelledby="by-year-heading">
              <h2 class="stats-card__title" id="by-year-heading">每年观看数量</h2>
              <div class="bar-chart" role="img" aria-label="每年观看数量柱状图">
                {(() => {
                  const maxCount = Math.max(...stats.byWatchYear.map(d => d.count), 1);
                  return stats.byWatchYear.map(({ year, count }) => (
                    <div class="bar-chart__item">
                      <div class="bar-chart__bar-wrap">
                        <div
                          class="bar-chart__bar"
                          style={`height: ${Math.max(4, (count / maxCount) * 100)}%`}
                          aria-hidden="true"
                        ></div>
                        <span class="bar-chart__count">{count}</span>
                      </div>
                      <span class="bar-chart__label">{year}</span>
                    </div>
                  ));
                })()}
              </div>
            </section>
          )}

          <!-- ── 类型分布 ──────────────────────────────── -->
          {stats.topGenres.length > 0 && (
            <section class="stats-card animate-fade-in-up delay-300" aria-labelledby="genre-heading">
              <h2 class="stats-card__title" id="genre-heading">类型分布</h2>
              <div class="progress-list">
                {(() => {
                  const maxCount = Math.max(...stats.topGenres.map(d => d.count), 1);
                  return stats.topGenres.map(({ genre, count }) => (
                    <div class="progress-item">
                      <div class="progress-item__header">
                        <span class="progress-item__label">{genre}</span>
                        <span class="progress-item__value">{count}</span>
                      </div>
                      <div class="progress-bar" aria-hidden="true">
                        <div
                          class="progress-bar__fill"
                          style={`width: ${(count / maxCount) * 100}%`}
                        ></div>
                      </div>
                    </div>
                  ));
                })()}
              </div>
            </section>
          )}

          <!-- ── 个人评分分布 ───────────────────────────── -->
          <section class="stats-card animate-fade-in-up delay-200" aria-labelledby="rating-dist-heading">
            <h2 class="stats-card__title" id="rating-dist-heading">个人评分分布</h2>
            <div class="rating-dist">
              {stats.ratingDist.reverse().map(({ star, count }) => (
                <div class="rating-dist__item">
                  <span class="rating-dist__star" aria-label={`${star} 星`}>
                    {'★'.repeat(star)}
                  </span>
                  <div class="progress-bar rating-dist__bar" aria-hidden="true">
                    <div
                      class="progress-bar__fill"
                      style={`width: ${stats.total > 0 ? (count / stats.total) * 100 : 0}%`}
                    ></div>
                  </div>
                  <span class="rating-dist__count">{count}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- ── 常见导演 ──────────────────────────────── -->
          {stats.topDirectors.length > 0 && (
            <section class="stats-card animate-fade-in-up delay-300" aria-labelledby="director-heading">
              <h2 class="stats-card__title" id="director-heading">最常看的导演</h2>
              <ol class="rank-list" role="list">
                {stats.topDirectors.map(({ director, count }, i) => (
                  <li class="rank-list__item">
                    <span class="rank-list__rank" aria-label={`第 ${i + 1} 名`}>{i + 1}</span>
                    <span class="rank-list__name">{director}</span>
                    <span class="rank-list__count">{count} 部</span>
                  </li>
                ))}
              </ol>
            </section>
          )}
        </div>
      </>
    )}

    <div style="height: var(--space-20);"></div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-20) 0 var(--space-10);
    border-bottom: 1px solid var(--border-subtle);
  }

  .page-header__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .page-header__title {
    font-size: var(--text-5xl);
    font-weight: 900;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-3);
  }

  .page-header__desc {
    font-size: var(--text-lg);
    color: var(--text-muted);
  }

  .section {
    padding: var(--space-10) 0;
  }

  .overview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .overview-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* 两列统计布局 */
  .stats-two-col {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    padding: var(--space-4) 0;
  }

  @media (max-width: 768px) {
    .stats-two-col { grid-template-columns: 1fr; }
  }

  /* 统计卡片 */
  .stats-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .stats-card__title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
    letter-spacing: -0.01em;
  }

  /* 柱状图 */
  .bar-chart {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
    height: 140px;
  }

  .bar-chart__item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    height: 100%;
  }

  .bar-chart__bar-wrap {
    flex: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    gap: var(--space-1);
  }

  .bar-chart__count {
    font-size: 10px;
    color: var(--text-muted);
    font-weight: 600;
  }

  .bar-chart__bar {
    width: 100%;
    background: linear-gradient(180deg, var(--color-accent), var(--color-accent-dim));
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    min-height: 4px;
    transition: height var(--transition-base);
  }

  .bar-chart__label {
    font-size: 10px;
    color: var(--text-muted);
    font-weight: 500;
    white-space: nowrap;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
  }

  /* 进度条列表 */
  .progress-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .progress-item__header {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-2);
  }

  .progress-item__label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
  }

  .progress-item__value {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-weight: 600;
  }

  .progress-bar {
    width: 100%;
    height: 6px;
    background: var(--bg-elevated);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .progress-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-dim));
    border-radius: var(--radius-full);
    transition: width 0.6s ease;
  }

  /* 评分分布 */
  .rating-dist {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .rating-dist__item {
    display: grid;
    grid-template-columns: 70px 1fr 30px;
    align-items: center;
    gap: var(--space-3);
  }

  .rating-dist__star {
    font-size: var(--text-xs);
    color: var(--color-accent);
    letter-spacing: 1px;
  }

  .rating-dist__bar {
    height: 8px;
  }

  .rating-dist__count {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-weight: 600;
    text-align: right;
  }

  /* 排名列表 */
  .rank-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .rank-list__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    background: var(--bg-elevated);
    border-radius: var(--radius-md);
  }

  .rank-list__rank {
    width: 24px;
    height: 24px;
    border-radius: var(--radius-full);
    background: var(--color-accent-glow);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: 700;
    flex-shrink: 0;
  }

  .rank-list__name {
    flex: 1;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
  }

  .rank-list__count {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-weight: 600;
  }
</style>
