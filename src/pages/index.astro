---
/**
 * 首页 — 个人电影墙主页
 * 视觉冲击力强的个人电影档案入口
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import MovieCard from "../components/MovieCard.astro";
import StarRating from "../components/StarRating.astro";
import { siteConfig } from "../config/site";
import {
  getAllMovies,
  getRecentMovies,
  getStats,
  formatRating,
} from "../utils/data";
import { getAllBooks } from "../utils/books";

const movies = await getAllMovies();
const recent = await getRecentMovies(6);
const stats = await getStats();
const books = await getAllBooks();
const movieCount = movies.filter((movie) => movie.mediaType === "movie").length;
const tvCount = movies.filter((movie) => movie.mediaType === "tv").length;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// 精选电影：优先个人评分，其次豆瓣评分，确保视觉精选区始终有内容
const featured = [...movies]
  .filter((m) => m.poster)
  .sort((a, b) =>
    (b.personalRating ?? 0) - (a.personalRating ?? 0) ||
    (b.doubanRating ?? 0) - (a.doubanRating ?? 0)
  )
  .slice(0, 3);

// 首屏背景电影（最近观看中有海报的）
const heroBgMovie = recent.find((m) => m.poster);
const heroTitleWords = siteConfig.title.split(/\s+/);
const marqueeWords = ["Watch", "Feel", "Archive", "Repeat"];
---

<BaseLayout
  title={undefined}
  description={siteConfig.description}
  bodyClass="home-page"
>
  <!-- ── 首屏英雄区 ─────────────────────────────────────── -->
  <section class="hero" data-home-hero aria-labelledby="hero-title">
    <!-- 背景氛围 -->
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__bg-gradient"></div>
      {heroBgMovie?.poster && (
        <img
          class="hero__bg-img"
          src={heroBgMovie.poster}
          data-fallback-src={heroBgMovie.posterFallback}
          alt=""
          loading="eager"
          decoding="async"
          referrerpolicy="no-referrer"
          onerror="if(this.dataset.fallbackSrc){this.src=this.dataset.fallbackSrc;this.removeAttribute('data-fallback-src');}else{this.style.display='none';}"
          aria-hidden="true"
        />
      )}
      <div class="hero__bg-overlay"></div>
      <div class="hero__grid"></div>
      <div class="hero__prism hero__prism--pink"></div>
      <div class="hero__prism hero__prism--cyan"></div>
      <div class="hero__crosshair hero__crosshair--one">+</div>
      <div class="hero__crosshair hero__crosshair--two">+</div>
    </div>

    <!-- 胶片装饰 -->
    <div class="hero__film-strip hero__film-strip--top" aria-hidden="true">
      <div class="film-strip">
        {[...Array(24)].map(() => (
          <div class="film-strip__hole"></div>
        ))}
      </div>
    </div>
    <div class="hero__film-strip hero__film-strip--bottom" aria-hidden="true">
      <div class="film-strip">
        {[...Array(24)].map(() => (
          <div class="film-strip__hole"></div>
        ))}
      </div>
    </div>

    <div class="container hero__layout">
      <div class="hero__content">
        <p class="hero__eyebrow">
          <span class="hero__eyebrow-dot"></span>
          <span>Vexpaer’s moving image archive</span>
          <span class="hero__eyebrow-code" aria-hidden="true">FW / 001</span>
        </p>

        <h1 class="hero__title" id="hero-title" aria-label={siteConfig.title}>
          {heroTitleWords.map((word, index) => (
            <span
              class:list={["hero__title-word", { "hero__title-word--outline": index % 2 === 1 }]}
              aria-hidden="true"
            >
              <span>{word}</span>
            </span>
          ))}
        </h1>

        <p class="hero__subtitle">
          让每一次观看留下坐标。<br />
          <span>{siteConfig.description}</span>
        </p>

        <div class="hero__meta" aria-label="档案概览">
          <span><strong>{movies.length}</strong> TITLES</span>
          <span><strong>{books.length}</strong> BOOKS</span>
          <span><strong>∞</strong> FEELINGS</span>
        </div>

        <div class="hero__actions">
          <a href={`${base}/movies/`} class="btn btn-primary hero__cta">
            <span class="hero__cta-icon" aria-hidden="true">▶</span>
            进入放映厅
          </a>
          <a href={`${base}/stats/`} class="btn btn-secondary">
            查看档案数据
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      {heroBgMovie?.poster && (
        <div class="hero__poster-scene" aria-hidden="true">
          <div class="hero__orbit hero__orbit--outer"></div>
          <div class="hero__orbit hero__orbit--inner"></div>
          <span class="hero__orbit-label hero__orbit-label--top">NOW SCREENING</span>
          <span class="hero__orbit-label hero__orbit-label--bottom">PERSONAL SELECTION</span>

          <div class="hero__poster-card">
            <div class="hero__poster-glitch"></div>
            <img
              src={heroBgMovie.poster}
              data-fallback-src={heroBgMovie.posterFallback}
              alt=""
              loading="eager"
              decoding="async"
              referrerpolicy="no-referrer"
              onerror="if(this.dataset.fallbackSrc){this.src=this.dataset.fallbackSrc;this.removeAttribute('data-fallback-src');}else{this.style.display='none';}"
            />
            <span class="hero__poster-corner hero__poster-corner--tl"></span>
            <span class="hero__poster-corner hero__poster-corner--tr"></span>
            <span class="hero__poster-corner hero__poster-corner--bl"></span>
            <span class="hero__poster-corner hero__poster-corner--br"></span>
            <div class="hero__poster-caption">
              <span>LAST WATCHED</span>
              <strong>{heroBgMovie.title}</strong>
            </div>
          </div>

          <div class="hero__ticket">
            <span>ADMIT ONE</span>
            <strong>FILM / WALL</strong>
            <small>NO. {String(movies.length).padStart(4, "0")}</small>
          </div>
        </div>
      )}
    </div>

    <div class="hero__scroll-cue" aria-hidden="true">
      <span>SCROLL TO DEVELOP</span>
      <i></i>
    </div>
  </section>

  <!-- ── 电影跑马灯 ───────────────────────────────────── -->
  <div class="cinema-marquee" aria-hidden="true">
    <div class="cinema-marquee__track">
      {[0, 1].map(() => (
        <div class="cinema-marquee__group">
          {marqueeWords.map((word, index) => (
            <span class="cinema-marquee__item">
              <span class:list={["cinema-marquee__word", { "cinema-marquee__word--outline": index % 2 === 1 }]}>{word}</span>
              <span class="cinema-marquee__star">✦</span>
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- ── 快速统计 ───────────────────────────────────────── -->
  <section class="stats-section" aria-labelledby="stats-heading">
    <div class="container">
      <div class="stats-section__header">
        <span class="stats-section__index" aria-hidden="true">01 / ARCHIVE PULSE</span>
        <h2 id="stats-heading">你的观看，<em>正在发光。</em></h2>
      </div>
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-card__index" aria-hidden="true">01</span>
          <span class="stat-card__flare" aria-hidden="true"></span>
          <div class="stat-card__number" data-count={stats.total} data-decimals="0">{stats.total}</div>
          <div class="stat-card__label">已看电影</div>
        </div>
        <div class="stat-card">
          <span class="stat-card__index" aria-hidden="true">02</span>
          <span class="stat-card__flare" aria-hidden="true"></span>
          <div
            class="stat-card__number"
            data-count={stats.avgRating > 0 ? stats.avgRating : undefined}
            data-decimals="1"
          >{stats.avgRating > 0 ? formatRating(stats.avgRating) : '—'}</div>
          <div class="stat-card__label">平均评分</div>
        </div>
        <div class="stat-card">
          <span class="stat-card__index" aria-hidden="true">03</span>
          <span class="stat-card__flare" aria-hidden="true"></span>
          <div class="stat-card__number" data-count={stats.ratedCount} data-decimals="0">{stats.ratedCount}</div>
          <div class="stat-card__label">已评分</div>
        </div>
        <div class="stat-card stat-card--genre">
          <span class="stat-card__index" aria-hidden="true">04</span>
          <span class="stat-card__flare" aria-hidden="true"></span>
          <div class="stat-card__number">{stats.topGenres[0]?.genre || '—'}</div>
          <div class="stat-card__label">最喜欢的类型</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 最近观看 ───────────────────────────────────────── -->
  {recent.length > 0 && (
    <section class="section section--recent" data-home-section aria-labelledby="recent-heading">
      <div class="container">
        <div class="section__header">
          <div>
            <span class="section__eyebrow">02 / LATEST EXPOSURES</span>
            <h2 class="section__title" id="recent-heading">新鲜<span>显影</span></h2>
          </div>
          <a href={`${base}/movies/`} class="btn btn-ghost section__more-btn">
            查看完整片库 <span aria-hidden="true">↗</span>
          </a>
        </div>

        <div class="movie-grid home-movie-grid">
          {recent.map((movie) => (
            <MovieCard movie={movie} showDate={true} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── 影评精选 ───────────────────────────────────────── -->
  {featured.length > 0 && (
    <section class="section section--featured" data-featured-section aria-labelledby="featured-heading">
      <div class="featured-pin">
        <div class="container featured-pin__inner">
          <div class="section__header featured-header">
            <div>
              <span class="section__eyebrow">03 / CRITIC’S CUT</span>
              <h2 class="section__title" id="featured-heading">私人<span>放映笔记</span></h2>
            </div>
            <p class="featured-header__hint" aria-hidden="true">SCROLL TO ROLL →</p>
          </div>

          <div class="featured-viewport">
            <div class="featured-grid featured-track">
              {featured.map((movie, i) => (
                <a
                  href={`${base}/${movie.mediaType === "tv" ? "tv" : "movies"}/${movie.id}/`}
                  class="featured-card"
                  aria-label={`${movie.title} — 查看详情`}
                >
                  <span class="featured-card__number" aria-hidden="true">0{i + 1}</span>
                  {movie.poster && (
                    <div class="featured-card__poster">
                      <img
                        src={movie.poster}
                        data-fallback-src={movie.posterFallback}
                        alt={`${movie.title} 海报`}
                        loading="lazy"
                        decoding="async"
                        referrerpolicy="no-referrer"
                        onerror="if(this.dataset.fallbackSrc){this.src=this.dataset.fallbackSrc;this.removeAttribute('data-fallback-src');}else{this.parentElement.classList.add('no-img');}"
                      />
                      <div class="featured-card__poster-overlay"></div>
                    </div>
                  )}
                  <div class="featured-card__content">
                    <div class="featured-card__meta">
                      {movie.year && <span class="featured-card__year">EST. {movie.year}</span>}
                    </div>
                    <h3 class="featured-card__title">{movie.title}</h3>
                    <p class="featured-card__review">
                      “{(movie.review || movie.shortComment || "私人高分收藏。某些画面结束了，余韵却仍停留在银幕之外。")
                        .replace(/[#*]/g, "")
                        .slice(0, 120)}”
                    </p>
                    <div class="featured-card__rating">
                      {movie.personalRating && (
                        <StarRating rating={movie.personalRating} size="sm" />
                      )}
                      {movie.doubanRating && (
                        <span class="featured-card__douban-rating">
                          豆瓣 {formatRating(movie.doubanRating)}
                        </span>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── 分类入口 ───────────────────────────────────────── -->
  <section class="section section--cta" data-cta-section aria-labelledby="wall-heading">
    <div class="container">
      <div class="cta-block">
        <div class="cta-block__orbit" aria-hidden="true">
          <i class="cta-block__ring cta-block__ring--one"></i>
          <i class="cta-block__ring cta-block__ring--two"></i>
          <span class="cta-block__satellite cta-block__satellite--movie">MOVIE</span>
          <span class="cta-block__satellite cta-block__satellite--tv">TV</span>
          <span class="cta-block__satellite cta-block__satellite--book">BOOK</span>
        </div>
        <p class="cta-block__eyebrow">04 / THE FINAL FRAME</p>
        <h2 class="cta-block__title" id="wall-heading">收藏不落幕，<span>下一场见。</span></h2>
        <p class="cta-block__desc">
          {movieCount} 部电影 · {tvCount} 部电视剧 · {books.length} 本书
        </p>
        <div class="cta-block__actions">
          <a href={`${base}/movies/`} class="btn btn-primary cta-block__btn">电影墙</a>
          <a href={`${base}/tv/`} class="btn btn-secondary cta-block__btn">电视剧墙</a>
          <a href={`${base}/books/`} class="btn btn-secondary cta-block__btn">书架</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── 首屏英雄区 ──────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 85dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    filter: blur(2px) saturate(0.5) brightness(0.3);
    transform: scale(1.05);
  }

  .hero__bg-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 60% 40%,
      rgba(245, 166, 35, 0.08) 0%,
      transparent 60%
    );
    z-index: 1;
  }

  .hero__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 15, 0.5) 0%,
      rgba(10, 10, 15, 0.4) 50%,
      var(--bg-base) 100%
    );
    z-index: 2;
  }

  /* 胶片装饰 */
  .hero__film-strip {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 3;
    pointer-events: none;
  }

  .film-strip {
    display: flex;
    gap: 20px;
    padding: 10px 24px;
    opacity: 0.15;
  }

  .film-strip__hole {
    width: 12px;
    height: 20px;
    border-radius: 3px;
    border: 2px solid var(--color-accent);
    flex-shrink: 0;
    animation: filmPulse 3s ease-in-out infinite;
  }

  @keyframes filmPulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  .hero .container {
    position: relative;
    z-index: 4;
    padding-top: var(--space-20);
    padding-bottom: var(--space-20);
  }

  .hero__content {
    max-width: 640px;
  }

  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .hero__eyebrow-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero__title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: var(--space-5);
    background: linear-gradient(
      135deg,
      #ffffff 0%,
      rgba(255, 255, 255, 0.8) 50%,
      var(--color-accent) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin-bottom: var(--space-8);
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero__cta {
    font-size: var(--text-base);
    padding: var(--space-4) var(--space-6);
  }

  /* ── 统计网格 ─────────────────────────────────────────── */
  .stats-section {
    padding: var(--space-16) 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── 通用 section ─────────────────────────────────────── */
  .section {
    padding: var(--space-16) 0;
  }

  .section__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: var(--space-8);
    gap: var(--space-4);
  }

  .section__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .section__title {
    font-size: var(--text-3xl);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .section__more-btn {
    flex-shrink: 0;
  }

  /* ── 精选网格 ─────────────────────────────────────────── */
  .section--featured {
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(245, 166, 35, 0.03) 50%,
      transparent 100%
    );
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  @media (max-width: 900px) {
    .featured-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .featured-grid { grid-template-columns: 1fr; }
  }

  .featured-card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
    min-height: 300px;
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-xl);
    border-color: var(--border-accent);
  }

  .featured-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .featured-card__poster {
    position: relative;
    height: 180px;
    overflow: hidden;
  }

  .featured-card__poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .featured-card:hover .featured-card__poster img {
    transform: scale(1.05);
  }

  .featured-card__poster-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--bg-card), transparent 50%);
  }

  .featured-card__content {
    padding: var(--space-5);
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .featured-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .featured-card__year {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-weight: 600;
  }

  .featured-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.2;
  }

  .featured-card__review {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .featured-card__rating {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: auto;
  }

  .featured-card__douban-rating {
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ── CTA 区域 ─────────────────────────────────────────── */
  .section--cta {
    padding: var(--space-24) 0;
  }

  .cta-block {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-block__eyebrow {
    font-size: 3rem;
    margin-bottom: var(--space-4);
  }

  .cta-block__title {
    font-size: var(--text-4xl);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
  }

  .cta-block__desc {
    font-size: var(--text-lg);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }

  .cta-block__btn {
    font-size: var(--text-lg);
    padding: var(--space-4) var(--space-8);
  }

  .cta-block__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
</style>

<style>
  /* ========================================================
     CINEMA MAXIMALISM — 首页视觉重制
     ======================================================== */

  .hero {
    min-height: calc(100svh - var(--nav-height));
    isolation: isolate;
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 5;
    height: 18%;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent, var(--bg-base));
  }

  .hero__bg-img {
    object-position: 72% 28%;
    opacity: 0.3;
    filter: saturate(0.25) contrast(1.16) brightness(0.42);
    transform: scale(1.08);
    will-change: transform;
  }

  .hero__bg-gradient {
    z-index: 1;
    background:
      radial-gradient(circle at 75% 42%, rgba(66, 232, 255, 0.2), transparent 20%),
      radial-gradient(circle at 72% 50%, rgba(255, 61, 154, 0.18), transparent 34%),
      radial-gradient(circle at 18% 38%, rgba(255, 212, 71, 0.15), transparent 28%);
  }

  .hero__bg-overlay {
    z-index: 2;
    background:
      linear-gradient(90deg, rgba(7, 7, 11, 0.98) 0%, rgba(7, 7, 11, 0.77) 46%, rgba(7, 7, 11, 0.2) 76%, rgba(7, 7, 11, 0.7) 100%),
      linear-gradient(180deg, rgba(7, 7, 11, 0.3), transparent 60%, var(--bg-base));
  }

  .hero__grid {
    position: absolute;
    inset: -10% -5%;
    z-index: 3;
    max-width: none;
    opacity: 0.23;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.09) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.09) 1px, transparent 1px);
    background-size: 78px 78px;
    transform: perspective(700px) rotateX(62deg) translateY(36%);
    transform-origin: bottom;
    mask-image: linear-gradient(to top, black, transparent 82%);
    will-change: transform;
  }

  .hero__prism {
    position: absolute;
    z-index: 3;
    width: clamp(220px, 26vw, 460px);
    aspect-ratio: 1;
    max-width: none;
    border-radius: 50%;
    opacity: 0.5;
    filter: blur(1px);
    mix-blend-mode: screen;
    will-change: transform;
  }

  .hero__prism::before,
  .hero__prism::after {
    content: "";
    position: absolute;
    border-radius: inherit;
  }

  .hero__prism::before {
    inset: 0;
    border: 1px solid currentColor;
    box-shadow: inset 0 0 80px currentColor, 0 0 50px currentColor;
    opacity: 0.18;
  }

  .hero__prism::after {
    inset: 18%;
    border: 1px dashed currentColor;
  }

  .hero__prism--pink {
    top: 12%;
    right: 4%;
    color: var(--color-pink);
  }

  .hero__prism--cyan {
    right: 29%;
    bottom: -10%;
    color: var(--color-cyan);
    transform: scale(0.56);
  }

  .hero__crosshair {
    position: absolute;
    z-index: 4;
    color: rgba(255, 255, 255, 0.55);
    font-family: var(--font-mono);
    font-size: 1.3rem;
  }

  .hero__crosshair--one {
    top: 19%;
    left: 46%;
  }

  .hero__crosshair--two {
    right: 4%;
    bottom: 25%;
    color: var(--color-cyan);
  }

  .hero__film-strip {
    right: -5%;
    left: -5%;
    z-index: 7;
    overflow: visible;
    max-width: none;
  }

  .hero__film-strip--bottom {
    top: auto;
    bottom: 0;
    transform: rotate(180deg);
  }

  .film-strip {
    width: max-content;
    max-width: none;
    gap: 28px;
    padding: 10px 0;
    opacity: 0.28;
    will-change: transform;
  }

  .film-strip__hole {
    width: 20px;
    height: 13px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 2px;
    animation: none;
  }

  .hero .hero__layout {
    position: relative;
    z-index: 6;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(340px, 0.82fr);
    align-items: center;
    gap: clamp(1rem, 5vw, 6rem);
    min-height: calc(100svh - var(--nav-height));
    padding-top: clamp(3rem, 7vh, 7rem);
    padding-bottom: clamp(5rem, 10vh, 9rem);
  }

  .hero__content {
    position: relative;
    z-index: 3;
    max-width: 820px;
    will-change: transform, opacity;
  }

  .hero__eyebrow {
    gap: 12px;
    margin-bottom: clamp(1rem, 2vh, 1.8rem);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.67rem;
    letter-spacing: 0.18em;
  }

  .hero__eyebrow::before {
    content: "";
    width: 42px;
    height: 1px;
    background: linear-gradient(90deg, var(--color-pink), var(--color-accent));
  }

  .hero__eyebrow-dot {
    width: 7px;
    height: 7px;
    background: var(--color-cyan);
    box-shadow: 0 0 18px var(--color-cyan);
  }

  .hero__eyebrow-code {
    margin-left: auto;
    padding: 4px 8px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    color: var(--color-accent);
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin: 0 0 clamp(1.3rem, 3vh, 2.4rem);
    overflow: visible;
    background: none;
    font-family: var(--font-display);
    font-size: clamp(7.2rem, 12.8vw, 13.8rem);
    font-weight: 400;
    line-height: 0.68;
    letter-spacing: -0.035em;
    text-transform: uppercase;
    -webkit-text-fill-color: initial;
  }

  .hero__title-word {
    display: block;
    overflow: hidden;
    padding: 0.06em 0.08em 0.05em 0;
    max-width: none;
  }

  .hero__title-word > span {
    display: block;
    color: #f5f4ff;
    text-shadow:
      0 0 48px rgba(255, 255, 255, 0.09),
      0 8px 0 rgba(255, 61, 154, 0.07);
    will-change: transform;
  }

  .hero__title-word--outline {
    align-self: flex-end;
    margin-top: 0.02em;
  }

  .hero__title-word--outline > span {
    color: transparent;
    -webkit-text-stroke: 2px var(--color-accent);
    text-shadow: 0 0 36px var(--color-accent-glow-strong);
  }

  .hero__subtitle {
    max-width: 540px;
    margin-bottom: 1.35rem;
    color: var(--text-primary);
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.6vw, 1.4rem);
    line-height: 1.7;
  }

  .hero__subtitle span {
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.78em;
  }

  .hero__meta {
    display: flex;
    gap: clamp(0.75rem, 2vw, 1.7rem);
    margin-bottom: 1.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
  }

  .hero__meta > span {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .hero__meta > span + span::before {
    content: "/";
    margin-right: clamp(0.2rem, 1vw, 0.8rem);
    color: rgba(255, 255, 255, 0.16);
  }

  .hero__meta strong {
    color: var(--color-cyan);
    font-size: 0.86rem;
  }

  .hero__actions {
    gap: 12px;
  }

  .hero__actions .btn {
    min-height: 54px;
    padding-inline: 24px;
    letter-spacing: 0.03em;
  }

  .hero__actions .btn-secondary {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.065);
  }

  .hero__cta-icon {
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border: 1px solid currentColor;
    border-radius: 50%;
    font-size: 0.55rem;
  }

  /* 首屏海报装置 */
  .hero__poster-scene {
    position: relative;
    width: min(38vw, 520px);
    aspect-ratio: 0.78;
    justify-self: end;
    max-width: none;
    perspective: 1000px;
    will-change: transform;
  }

  .hero__orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 0;
    aspect-ratio: 1;
    border-radius: 50%;
    max-width: none;
    transform: translate(-50%, -50%);
    will-change: transform;
  }

  .hero__orbit::before,
  .hero__orbit::after {
    content: "";
    position: absolute;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 20px currentColor;
  }

  .hero__orbit::before {
    top: -5px;
    left: 50%;
  }

  .hero__orbit::after {
    right: -5px;
    top: 50%;
  }

  .hero__orbit--outer {
    width: 112%;
    color: var(--color-pink);
    border: 1px dashed rgba(255, 61, 154, 0.32);
  }

  .hero__orbit--inner {
    width: 82%;
    color: var(--color-cyan);
    border: 1px solid rgba(66, 232, 255, 0.22);
  }

  .hero__orbit-label {
    position: absolute;
    z-index: 4;
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
  }

  .hero__orbit-label--top {
    top: -3%;
    right: 9%;
  }

  .hero__orbit-label--bottom {
    bottom: 2%;
    left: 3%;
    writing-mode: vertical-rl;
  }

  .hero__poster-card {
    position: absolute;
    top: 8%;
    left: 17%;
    z-index: 2;
    width: 66%;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    max-width: none;
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 3px;
    background:
      linear-gradient(125deg, transparent 0 28%, rgba(255, 61, 154, 0.22) 28% 31%, transparent 31% 60%, rgba(66, 232, 255, 0.2) 60% 64%, transparent 64%),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.025) 0 1px, transparent 1px 8px),
      radial-gradient(circle at 30% 20%, #2b203a, #10101a 55%, #08080d);
    box-shadow:
      24px 30px 80px rgba(0, 0, 0, 0.65),
      -12px -12px 50px rgba(66, 232, 255, 0.08),
      12px 12px 50px rgba(255, 61, 154, 0.1);
    transform: rotate(-4deg);
    will-change: transform;
  }

  .hero__poster-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(115deg, transparent 30%, rgba(255, 255, 255, 0.2) 48%, transparent 65%),
      linear-gradient(to top, rgba(7, 7, 11, 0.94), transparent 46%);
    background-size: 250% 100%, 100% 100%;
    background-position: 120% 0, 0 0;
    mix-blend-mode: screen;
  }

  .hero__poster-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.82) contrast(1.08);
  }

  .hero__poster-glitch {
    position: absolute;
    inset: 0;
    z-index: 3;
    opacity: 0;
    max-width: none;
    background:
      linear-gradient(transparent 28%, rgba(66, 232, 255, 0.55) 28% 34%, transparent 34% 62%, rgba(255, 61, 154, 0.5) 62% 67%, transparent 67%);
    mix-blend-mode: color-dodge;
    pointer-events: none;
  }

  .hero__poster-caption {
    position: absolute;
    right: 16px;
    bottom: 16px;
    left: 16px;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: none;
  }

  .hero__poster-caption span {
    color: var(--color-cyan);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.16em;
  }

  .hero__poster-caption strong {
    margin-top: 4px;
    color: white;
    font-size: clamp(0.85rem, 1.5vw, 1.15rem);
    line-height: 1.2;
  }

  .hero__poster-corner {
    position: absolute;
    z-index: 5;
    width: 18px;
    height: 18px;
    border-color: var(--color-accent);
    border-style: solid;
    pointer-events: none;
  }

  .hero__poster-corner--tl { top: 8px; left: 8px; border-width: 1px 0 0 1px; }
  .hero__poster-corner--tr { top: 8px; right: 8px; border-width: 1px 1px 0 0; }
  .hero__poster-corner--bl { bottom: 8px; left: 8px; border-width: 0 0 1px 1px; }
  .hero__poster-corner--br { right: 8px; bottom: 8px; border-width: 0 1px 1px 0; }

  .hero__ticket {
    position: absolute;
    right: -2%;
    bottom: 14%;
    z-index: 4;
    display: flex;
    flex-direction: column;
    width: 160px;
    padding: 14px 18px;
    border: 1px solid rgba(7, 7, 11, 0.18);
    background: var(--color-accent);
    color: #09090d;
    box-shadow: 12px 18px 40px rgba(0, 0, 0, 0.42);
    transform: rotate(8deg);
    clip-path: polygon(0 0, 100% 0, 100% 42%, 94% 50%, 100% 58%, 100% 100%, 0 100%, 0 58%, 6% 50%, 0 42%);
  }

  .hero__ticket span,
  .hero__ticket small {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.14em;
  }

  .hero__ticket strong {
    margin: 5px 0 12px;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.04em;
  }

  .hero__ticket small {
    padding-top: 8px;
    border-top: 1px dashed rgba(7, 7, 11, 0.42);
  }

  .hero__scroll-cue {
    position: absolute;
    right: 28px;
    bottom: 66px;
    z-index: 8;
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.16em;
    writing-mode: vertical-rl;
  }

  .hero__scroll-cue i {
    display: block;
    width: 1px;
    height: 58px;
    overflow: hidden;
    background: linear-gradient(to bottom, var(--color-cyan), transparent);
    box-shadow: 0 0 10px var(--color-cyan);
  }

  /* 横向字幕 */
  .cinema-marquee {
    position: relative;
    z-index: 3;
    overflow: hidden;
    max-width: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.018);
    transform: rotate(-1.4deg) scale(1.02);
    backdrop-filter: blur(12px);
  }

  .cinema-marquee__track {
    display: flex;
    width: max-content;
    max-width: none;
    will-change: transform;
  }

  .cinema-marquee__group {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: clamp(1.4rem, 3vw, 3.4rem);
    max-width: none;
    padding: 18px clamp(1.4rem, 3vw, 3.4rem) 15px 0;
  }

  .cinema-marquee__item {
    display: inline-flex;
    align-items: center;
    gap: clamp(1.4rem, 3vw, 3.4rem);
    max-width: none;
  }

  .cinema-marquee__word {
    color: #f4f2ff;
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 7vw, 7.8rem);
    line-height: 0.78;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .cinema-marquee__word--outline {
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.44);
  }

  .cinema-marquee__star {
    color: var(--color-pink);
    font-size: clamp(1.2rem, 2.2vw, 2.4rem);
    filter: drop-shadow(0 0 12px var(--color-pink));
  }

  /* 数据脉冲 */
  .stats-section {
    position: relative;
    z-index: 2;
    padding: clamp(7rem, 13vw, 12rem) 0 clamp(5rem, 9vw, 9rem);
  }

  .stats-section__header {
    display: grid;
    grid-template-columns: 0.35fr 1fr;
    align-items: end;
    gap: 2rem;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }

  .stats-section__index {
    padding-bottom: 0.7rem;
    color: var(--color-cyan);
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.16em;
  }

  .stats-section__header h2 {
    max-width: 820px;
    font-size: clamp(2.6rem, 6vw, 6.5rem);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .stats-section__header em {
    color: transparent;
    font-style: normal;
    -webkit-text-stroke: 1px var(--color-pink);
    filter: drop-shadow(0 0 22px var(--color-pink-glow));
  }

  .stats-grid {
    gap: clamp(0.75rem, 1.5vw, 1.35rem);
    perspective: 1100px;
  }

  .stat-card {
    position: relative;
    min-height: clamp(210px, 20vw, 310px);
    overflow: hidden;
    padding: clamp(1.2rem, 2vw, 2rem);
    text-align: left;
    border-radius: clamp(18px, 2vw, 30px);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.07), transparent 45%),
      rgba(17, 16, 27, 0.76);
    backdrop-filter: blur(20px);
    transform-style: preserve-3d;
  }

  .stat-card:nth-child(2) { transform: translateY(24px); }
  .stat-card:nth-child(3) { transform: translateY(-12px); }
  .stat-card:nth-child(4) { transform: translateY(14px); }

  .stat-card__index {
    position: absolute;
    top: 18px;
    right: 20px;
    color: rgba(255, 255, 255, 0.2);
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }

  .stat-card__flare {
    position: absolute;
    right: -30%;
    bottom: -40%;
    width: 85%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.1;
    filter: blur(42px);
    transition: opacity var(--transition-base), transform var(--transition-slow);
  }

  .stat-card:nth-child(2) .stat-card__flare { background: var(--color-pink); }
  .stat-card:nth-child(3) .stat-card__flare { background: var(--color-cyan); }

  .stat-card:hover .stat-card__flare {
    opacity: 0.22;
    transform: scale(1.2);
  }

  .stat-card__number {
    position: relative;
    z-index: 1;
    margin-top: auto;
    padding-top: clamp(3.4rem, 6vw, 6.4rem);
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 6vw, 7rem);
    font-weight: 400;
    line-height: 0.85;
    letter-spacing: -0.02em;
    text-shadow: 0 0 30px var(--color-accent-glow);
  }

  .stat-card:nth-child(2) .stat-card__number { color: var(--color-pink); }
  .stat-card:nth-child(3) .stat-card__number { color: var(--color-cyan); }

  .stat-card--genre .stat-card__number {
    overflow-wrap: anywhere;
    color: #f4f2ff;
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3.5vw, 3.7rem);
    font-weight: 700;
    line-height: 1.05;
  }

  .stat-card__label {
    position: relative;
    z-index: 1;
    margin-top: 1rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* 通用首页分区 */
  .section {
    position: relative;
    z-index: 2;
    padding: clamp(6rem, 11vw, 11rem) 0;
  }

  .section__header {
    align-items: center;
    margin-bottom: clamp(2.4rem, 5vw, 4.8rem);
  }

  .section__eyebrow {
    margin-bottom: 0.75rem;
    color: var(--color-cyan);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
  }

  .section__title {
    font-size: clamp(3rem, 7vw, 7.8rem);
    font-weight: 850;
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .section__title span {
    margin-left: 0.15em;
    color: transparent;
    -webkit-text-stroke: 1px var(--color-accent);
  }

  .section--recent::before {
    content: "";
    position: absolute;
    inset: 8% 0 auto;
    height: 55%;
    pointer-events: none;
    background: radial-gradient(ellipse at 24% 50%, rgba(66, 232, 255, 0.07), transparent 52%);
  }

  .home-movie-grid {
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: clamp(0.7rem, 1.5vw, 1.4rem);
    perspective: 1200px;
  }

  /* 横向影评胶卷 */
  .section--featured {
    min-height: 100svh;
    overflow: visible;
    padding: 0;
    background:
      radial-gradient(circle at 16% 35%, rgba(255, 61, 154, 0.08), transparent 35%),
      radial-gradient(circle at 82% 72%, rgba(66, 232, 255, 0.06), transparent 32%);
  }

  .featured-pin {
    display: flex;
    align-items: center;
    min-height: 100svh;
    overflow: hidden;
    max-width: none;
  }

  .featured-pin__inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    max-width: min(1600px, 100%);
  }

  .featured-header {
    margin-bottom: clamp(1.8rem, 3vw, 3.2rem);
  }

  .featured-header__hint {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    letter-spacing: 0.18em;
  }

  .featured-viewport {
    width: 100%;
    overflow: visible;
    max-width: none;
  }

  .featured-grid,
  .featured-track {
    display: flex;
    grid-template-columns: none;
    width: max-content;
    max-width: none;
    gap: clamp(1.2rem, 2.5vw, 2.8rem);
    padding-right: 10vw;
    will-change: transform;
  }

  .featured-card {
    display: grid;
    grid-template-columns: minmax(250px, 0.78fr) minmax(330px, 1fr);
    flex: 0 0 min(72vw, 920px);
    width: min(72vw, 920px);
    min-height: min(58vh, 570px);
    overflow: hidden;
    border-radius: clamp(22px, 3vw, 40px);
    background: rgba(17, 16, 27, 0.88);
    backdrop-filter: blur(24px);
  }

  .featured-card__number {
    position: absolute;
    top: 18px;
    right: 24px;
    z-index: 6;
    color: transparent;
    font-family: var(--font-display);
    font-size: clamp(4rem, 7vw, 7rem);
    line-height: 1;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.14);
  }

  .featured-card__poster {
    height: 100%;
